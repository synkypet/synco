# ──────────────────────────────────────────────────────────────────────────────
# SYNCO — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores reais.
# NUNCA commite o .env.local no repositório.
# ──────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── App ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://app.synco.com.br
NEXT_PUBLIC_APP_NAME=SYNCO

# ── Mercado Pago ───────────────────────────────────────────────────────────────
MERCADO_PAGO_ACCESS_TOKEN=your-mp-access-token
MERCADO_PAGO_WEBHOOK_SECRET=your-mp-webhook-secret

# ── Wasender ──────────────────────────────────────────────────────────────────
WASENDER_API_URL=https://wasenderapi.com/api
WASENDER_PAT=your-wasender-pat-here
WASENDER_WEBHOOK_SECRET=your-wasender-webhook-secret

# ── Google AI (Gemini) ────────────────────────────────────────────────────────
GOOGLE_GENERATIVE_AI_API_KEY=your-google-ai-key

# ── Cron Protection ──────────────────────────────────────────────────────────
# Secret para proteger as rotas /api/send-jobs/process e /api/maintenance/cleanup
CRON_SECRET=your-cron-secret-here

# ── Resend (Email) ────────────────────────────────────────────────────────────
RESEND_API_KEY=your-resend-key
